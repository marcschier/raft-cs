<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Pin restore to nuget.org only. Central Package Management forbids ambiguous
    multi-source restore, and machine/user-level feeds (e.g. a GitHub Packages
    source) must not leak into this repo's restore. Publishing to GitHub Packages
    is done explicitly via `dotnet nuget push` with a source URL + token in CI.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
